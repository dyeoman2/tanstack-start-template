{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/server.ts",
    "src/routes/**/*.{tsx,ts}",
    "scripts/**/*.ts",
    "*.config.{ts,js,mjs}",
    "convex/**/*.{ts,js}"
  ],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{ts,tsx}", "convex/**/*.{ts,js}"],
  "ignore": [
    "src/components/ui/**/*",
    "src/router.tsx"
  ],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "error",
    "nsTypes": "warn",
    "enumMembers": "error",
    "classMembers": "error"
  },
  "ignoreDependencies": [
    "@napi-rs/canvas",
    "pdf-parse",
    "tailwindcss-animate"
  ],
  "ignoreBinaries": ["vite-bundle-analyzer"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
