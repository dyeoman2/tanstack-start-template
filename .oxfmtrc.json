{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".cursor/**",
    "src/routeTree.gen.ts",
    "worker-configuration.d.ts",
    "convex/_generated/**",
    "convex/betterAuth/_generated/**",
    ".claude/**",
    "compliance/sources/**",
    "compliance/generated/**/*.json"
  ]
}
