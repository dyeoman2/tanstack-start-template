{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/server.ts",
    "src/routes/**/*.{tsx,ts}",
    "scripts/**/*.ts",
    "*.config.{ts,js,mjs}",
    "convex/**/*.{ts,tsx,js}",
    "infra/**/*.{ts,tsx,js,mjs,cts}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,tsx}",
    "convex/**/*.{ts,tsx,js}",
    "infra/**/*.{ts,tsx,js,mjs,cts}"
  ],
  "ignore": ["src/components/ui/**/*", "src/router.tsx", "infra/aws-cdk/cdk.out/**/*"],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "error",
    "nsTypes": "warn",
    "enumMembers": "error"
  },
  "ignoreDependencies": [
    "@napi-rs/canvas",
    "aws-cdk",
    "pdf-parse",
    "tailwindcss",
    "tailwindcss-animate"
  ],
  "ignoreBinaries": ["vite-bundle-analyzer", "build"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
