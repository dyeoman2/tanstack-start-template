{
  "name": "tanstack-start-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": "Daniel Yeoman",
  "version": "1.0.0",
  "description": "TanStack Start Template built with TanStack Start, Better Auth, Convex, Tailwind CSS, Shadcn/UI, and Resend",
  "homepage": "https://github.com/dyeoman2/tanstack-start-template",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyeoman2/tanstack-start-template.git"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "tanstack start",
    "react",
    "typescript",
    "starter",
    "template",
    "fullstack",
    "authentication",
    "convex",
    "resend",
    "netlify"
  ],
  "scripts": {
    "dev": "concurrently -n vite,convex -c blue,green \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev\" \"pnpm exec convex dev\"",
    "dev:full": "tsx scripts/dev-full.ts",
    "build": "vite build && mkdir -p .output/server && cp instrument.server.mjs .output/server",
    "start": "node --import ./.output/server/instrument.server.mjs ./.output/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:server": "tsx scripts/e2e-dev.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fix": "biome check --write .",
    "knip": "knip",
    "knip:prod": "knip --production",
    "setup:env": "tsx scripts/setup-env.ts",
    "setup:e2e": "tsx scripts/setup-e2e.ts",
    "setup:convex": "tsx scripts/setup-convex.ts",
    "setup:dev": "tsx scripts/setup-dev.ts",
    "setup:prod": "tsx scripts/setup-prod.ts",
    "make-admin": "tsx scripts/make-admin.ts",
    "precommit": "biome check --write",
    "updates": "npx npm-check-updates",
    "analyze": "pnpm build && npx vite-bundle-analyzer dist/client/assets/*.js",
    "infra:deploy": "tsx infra/storage.ts",
    "infra:preview": "tsx infra/storage.ts --preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@better-auth/core": "1.4.9",
    "@better-auth/passkey": "^1.4.9",
    "@better-auth/utils": "0.3.0",
    "@better-fetch/fetch": "1.1.21",
    "@captchafox/react": "^1.11.0",
    "@convex-dev/better-auth": "^0.10.13",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@daveyplate/better-auth-tanstack": "^1.3.6",
    "@daveyplate/better-auth-ui": "^3.3.15",
    "@hookform/resolvers": "^5.2.2",
    "@instantdb/react": "^0.22.157",
    "@marsidev/react-turnstile": "^1.4.2",
    "@mendable/firecrawl-js": "^4.15.4",
    "@netlify/vite-plugin-tanstack-start": "^1.2.20",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/profiling-node": "^10.43.0",
    "@sentry/tanstackstart-react": "^10.43.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-start": "^1.166.7",
    "@tanstack/react-table": "^8.21.3",
    "@triplit/client": "^1.0.50",
    "@triplit/react": "^1.0.51",
    "@useautumn/convex": "^0.0.23",
    "ai": "^6.0.116",
    "autumn-js": "^0.1.85",
    "better-auth": "^1.4.9",
    "better-call": "1.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "npm-check-updates": "^19.6.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "vite": "7.3.1",
    "workers-ai-provider": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-iam": "^3.1006.0",
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@better-auth/core": "1.4.9",
      "@better-auth/utils": "0.3.0",
      "@better-fetch/fetch": "1.1.21",
      "better-call": "1.1.7"
    }
  }
}
