{
  "name": "tanstack-start-template",
  "version": "1.0.0",
  "private": true,
  "description": "TanStack Start chat template built with TanStack Start, Better Auth, Convex, Tailwind CSS, shadcn/ui, and OpenRouter via Vercel AI SDK",
  "keywords": [
    "authentication",
    "convex",
    "fullstack",
    "netlify",
    "react",
    "resend",
    "starter",
    "tanstack start",
    "template",
    "typescript"
  ],
  "homepage": "https://github.com/dyeoman2/tanstack-start-template",
  "license": "MIT",
  "author": "Daniel Yeoman",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyeoman2/tanstack-start-template.git"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "concurrently -n vite,convex -c blue,green \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev\" \"pnpm exec convex dev\"",
    "dev:full": "tsx scripts/dev-full.ts",
    "build": "vite build",
    "start": "node --import ./instrument.server.mjs ./scripts/start-server.mjs",
    "test": "vitest run",
    "test:ssr-smoke": "pnpm run build && node ./scripts/smoke-ssr-runtime.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:server": "tsx scripts/e2e-dev.ts",
    "agent:auth": "tsx scripts/agent-browser-auth.ts",
    "agent:close": "tsx scripts/agent-browser-close.ts",
    "agent:inspect": "tsx scripts/agent-browser-inspect.ts",
    "playwright:inspect": "tsx scripts/playwright-inspect.ts",
    "typecheck": "./oxlint-typecheck.sh",
    "lint": "pnpm exec oxlint --fix .",
    "lint:convex": "pnpm exec oxlint -c .oxlintrc-convex.json convex --ignore-pattern 'convex/_generated/**' --ignore-pattern 'convex/betterAuth/_generated/**' --ignore-pattern 'convex/**/*.test.ts' --ignore-pattern 'convex/**/__tests__/**'",
    "lint:security": "pnpm exec oxlint -c .oxlintrc-security.json convex --ignore-pattern 'convex/_generated/**' --ignore-pattern 'convex/betterAuth/_generated/**' --ignore-pattern 'convex/**/*.test.ts' --ignore-pattern 'convex/**/__tests__/**'",
    "check:admin-audit-guardrails": "node ./scripts/check-admin-audit-guardrails.mjs",
    "lint:check": "pnpm exec oxlint .",
    "lint-staged": "lint-staged",
    "check": "pnpm exec oxfmt --check . && pnpm run lint:check && pnpm run typecheck && pnpm audit:code-health",
    "audit:code-health": "node --import tsx scripts/code-health-audit.ts check",
    "audit:inventory": "tsx scripts/code-health-audit.ts inventory",
    "compliance:extract:nist-80053-moderate": "node scripts/compliance/extract-nist-80053-moderate.ts",
    "compliance:extract:hipaa-security-rule": "node scripts/compliance/extract-hipaa-security-rule.ts",
    "compliance:extract:csf-2.0": "node scripts/compliance/extract-csf-2-references.ts",
    "compliance:extract:nist-80066": "node scripts/compliance/extract-nist-80066-cprt.ts",
    "compliance:extract:soc2": "node scripts/compliance/extract-soc2-tsc.ts",
    "compliance:generate:active-control-register": "node scripts/compliance/generate-active-control-register.ts",
    "compliance:refresh": "pnpm run compliance:extract:nist-80053-moderate && pnpm run compliance:extract:hipaa-security-rule && pnpm run compliance:extract:csf-2.0 && pnpm run compliance:extract:nist-80066 && pnpm run compliance:extract:soc2 && pnpm run compliance:generate:active-control-register",
    "seed": "tsx scripts/seed.ts",
    "seed:dry-run": "tsx scripts/seed.ts --dry-run",
    "knip": "knip",
    "knip:prod": "knip --production",
    "setup:env": "tsx scripts/setup-env.ts",
    "setup:github-deploy": "tsx scripts/setup-github-deploy.ts",
    "storage:setup": "tsx scripts/setup-storage.ts",
    "storage:setup:prod": "tsx scripts/setup-storage-prod.ts",
    "setup:e2e": "tsx scripts/setup-e2e.ts",
    "setup:convex": "tsx scripts/setup-convex.ts",
    "setup:dev": "tsx scripts/setup-dev.ts",
    "setup:prod": "tsx scripts/setup-prod.ts",
    "dr:setup": "tsx scripts/setup-dr.ts",
    "dr:netlify:setup": "tsx scripts/setup-dr-netlify.ts",
    "better-auth:generate-schema": "pnpm exec better-auth generate --config better-auth.cli.ts --output /tmp/better-auth-generated-schema.ts -y",
    "verify:better-auth": "node scripts/verify-better-auth.mjs",
    "make-admin": "tsx scripts/make-admin.ts",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "prepare": "husky",
    "precommit": "pnpm run format && pnpm run lint",
    "updates": "npx npm-check-updates",
    "analyze": "pnpm build && npx vite-bundle-analyzer dist/client/assets/*.js",
    "storage:deploy:dev": "tsx infra/storage.ts --stage dev",
    "storage:preview:dev": "tsx infra/storage.ts --preview --stage dev",
    "storage:deploy:prod": "tsx infra/storage.ts --stage prod",
    "storage:preview:prod": "tsx infra/storage.ts --preview --stage prod",
    "storage:destroy:dev": "tsx scripts/destroy-storage.ts --stage dev",
    "storage:destroy:prod": "tsx scripts/destroy-storage.ts --stage prod",
    "dr:backup:deploy": "tsx infra/dr.ts --stack tanstack-start-template-dr-backup-stack",
    "dr:backup:preview": "tsx infra/dr.ts --preview --stack tanstack-start-template-dr-backup-stack",
    "dr:backup:destroy": "tsx scripts/destroy-dr.ts --stack backup",
    "dr:ecs:deploy": "tsx infra/dr.ts --stack tanstack-start-template-dr-ecs-stack",
    "dr:ecs:preview": "tsx infra/dr.ts --preview --stack tanstack-start-template-dr-ecs-stack",
    "dr:ecs:destroy": "tsx scripts/destroy-dr.ts --stack ecs",
    "dr:deploy": "tsx infra/dr.ts --all",
    "dr:destroy": "tsx scripts/destroy-dr.ts --stack all",
    "dr:preview": "tsx infra/dr.ts --preview --all",
    "dr:sync-env": "bash ./scripts/sync-dr-env-to-secrets-manager.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@better-auth/passkey": "1.5.5",
    "@better-auth/scim": "^1.5.5",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/better-auth": "^0.11.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@napi-rs/canvas": "^0.1.97",
    "@netlify/vite-plugin-tanstack-start": "^1.3.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@openrouter/sdk": "^0.9.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sentry/profiling-node": "^10.44.0",
    "@sentry/tanstackstart-react": "^10.44.0",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-start": "^1.166.17",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.116",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "npm-check-updates": "^19.6.5",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "read-excel-file": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.166.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-cdk": "^2.1112.0",
    "aws-cdk-lib": "^2.243.0",
    "concurrently": "^9.2.1",
    "constructs": "^10.5.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "knip": "^5.88.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "8.0.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,cts,mts}": [
      "node scripts/run-ox-tools-on-staged.mjs"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
